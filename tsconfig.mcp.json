{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist-mcp",
    "rootDir": "mcp-server",
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": ["mcp-server"]
}
